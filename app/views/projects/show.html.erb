<p><%= link_to "← Back to projects", projects_path %></p>

<h1 class="mb-1"><%= @project.title %></h1>
<p class="text-muted mb-3">
  <%= @project.category.humanize %> • <%= @project.level.humanize %> • <%= @project.duration.humanize %> • Max <%= @project.max_team_members %>
</p>

<div class="card p-3 mb-3">
  <h3>Description</h3>
  <p><%= simple_format(@project.full_description) %></p>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card p-3">
      <h4>Tech Stack</h4>
      <ul class="mb-0">
        <% @project.tech_stack.each do |t| %><li><%= t %></li><% end %>
      </ul>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card p-3">
      <h4>Team Roles</h4>
      <ul class="mb-0">
        <% @project.team_roles.each do |r| %><li><%= r %></li><% end %>
      </ul>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card p-3">
      <h4>Objectives</h4>
      <ul class="mb-0">
        <% @project.objectives.each do |o| %><li><%= o %></li><% end %>
      </ul>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card p-3">
      <h4>Timeline</h4>
      <ul class="mb-0">
        <% @project.timeline.each do |p| %><li><%= p %></li><% end %>
      </ul>
    </div>
  </div>
</div>

<div class="mt-4 d-flex gap-2">
  <% if @project.status_draft? %>
    <%= button_to "Publish Project", publish_project_path(@project), method: :patch, class: "btn btn-success" %>
  <% else %>
    <span class="badge bg-success align-self-center">Published</span>
  <% end %>
</div>
