<h1>Create a New Project</h1>
<p class="text-muted">Fill the form, then Codi generates a full dev project spec.</p>

<%= form_with model: @project do |f| %>
  <% if @project.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @project.errors.full_messages.each do |m| %>
          <li><%= m %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card p-3">
    <div class="mb-3">
      <%= f.label :title, "Project title*", class: "form-label" %>
      <%= f.text_field :title, class: "form-control", placeholder: "e.g., Task Management App with Real-time Collaboration" %>
    </div>

    <div class="mb-3">
      <%= f.label :short_description, "Short Description*", class: "form-label" %>
      <%= f.text_field :short_description, class: "form-control", maxlength: 150, placeholder: "Max 150 characters" %>
    </div>

    <div class="mb-3">
      <%= f.label :full_description, "Full Description*", class: "form-label" %>
      <%= f.text_area :full_description, class: "form-control", rows: 4, placeholder: "Describe the idea, users, constraints..." %>
    </div>

    <div class="row g-2 mb-3">
      <div class="col-md-6">
        <%= f.label :category, "Category*", class: "form-label" %>
        <%= f.select :category, Project.categories.keys.map { |k| [k.humanize, k] },
              { include_blank: "Select a category" }, class: "form-select" %>
      </div>

      <div class="col-md-6">
        <%= f.label :duration, "Duration*", class: "form-label" %>
        <%= f.select :duration, Project.durations.keys.map { |k| [k.humanize, k] },
              { include_blank: "Select a duration" }, class: "form-select" %>
      </div>
    </div>

    <div class="row g-2 mb-3">
      <div class="col-md-6">
        <%= f.label :level, "Level*", class: "form-label" %>
        <%= f.select :level, Project.levels.keys.map { |k| [k.humanize, k] },
              { include_blank: "Select a level" }, class: "form-select" %>
      </div>

      <div class="col-md-6">
        <%= f.label :max_team_members, "Max team members*", class: "form-label" %>
        <%= f.select :max_team_members, (2..10).to_a, {}, class: "form-select" %>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary w-50" %>
      <%= f.submit "Générer mon projet avec Codi", class: "btn btn-warning w-50" %>
    </div>
  </div>
<% end %>
