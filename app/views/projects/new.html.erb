<h1 class="text-center mb-4 fw-bold" style="color: black;">
  Créer un nouveau projet
  </h1>
<p class=" text-center mb-4 text-muted">Remplis le formulaire et fais toi aider par Codi pour affiner !</p>

<%= form_with model: @project do |f| %>
  <% if @project.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @project.errors.full_messages.each do |m| %>
          <li><%= m %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card p-3 shadow-sm border-2 border-warning">
    <div class="card-title mb-1">
      <%= f.label :title, "Nom de ton projet*", class: "form-label" %>
      <%= f.text_field :title, class: "form-control", placeholder: "Ex: Application Task Management" %>
    </div>

    <div class="card-title mb-1">
      <%= f.label :short_description, "Description courte*", class: "form-label" %>
      <%= f.text_field :short_description, class: "form-control", maxlength: 150, placeholder: "Max 150 caractères" %>
    </div>

    <div class="card-title mb-1">
      <%= f.label :full_description, "Description complète*", class: "form-label" %>
      <%= f.text_area :full_description, class: "form-control", rows: 4, placeholder: "Décris l'idée, les utilisateurs, les contraintes..." %>
    </div>

    <div class="row g-2 mb-3">
      <div class="col-md-6">
        <%= f.label :category, "Categorie*", class: "form-label" %>
        <%= f.select :category, Project.categories.keys.map { |k| [k.humanize, k] },
              { include_blank: "Selectionne une catégorie" }, class: "form-select" %>
      </div>

      <div class="col-md-6">
        <%= f.label :duration, "Durée*", class: "form-label" %>
        <%= f.select :duration, Project.durations.keys.map { |k| [k.humanize, k] },
              { include_blank: "Selectionne une durée" }, class: "form-select" %>
      </div>
    </div>

    <div class="row g-2 mb-3">
      <div class="col-md-6">
        <%= f.label :level, "Niveau*", class: "form-label" %>
        <%= f.select :level, Project.levels.keys.map { |k| [k.humanize, k] },
              { include_blank: "Selectionne un niveau" }, class: "form-select" %>
      </div>

      <div class="col-md-6">
        <%= f.label :max_team_members, "Nombre maximum de membres d'équipe*", class: "form-label" %>
        <%= f.select :max_team_members, (2..10).to_a, {}, class: "form-select" %>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Annuler", root_path, class: "btn btn-outline-secondary w-50" %>
      <%= f.submit "Générer mon projet avec Codi", class: "btn btn-warning w-50" %>
    </div>
  </div>
<% end %>
