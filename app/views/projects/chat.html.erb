<p><%= link_to "← Retour au projet", project_path(@project) %></p>

<h1>Chat avec Codi</h1>
<p class="text-muted">Codi a déjà le contexte du projet en mémoire. Donne ton feedback, il mettra à jour le projet.</p>

<div class="card p-3 mb-3" style="max-height: 55vh; overflow:auto;">
  <% @messages.each do |m| %>
    <div class="mb-2">
      <strong><%= m.role == "user" ? "Toi" : "Codi" %>:</strong>
      <div><%= simple_format(m.content) %></div>
    </div>
  <% end %>
</div>

<%= form_with url: project_messages_path(@project), method: :post do %>
  <div class="mb-2">
    <%= text_area_tag "message[content]", "", class: "form-control", rows: 3, placeholder: "Ex: Remplace AWS par Heroku et propose une stack Rails + Postgres." %>
  </div>
  <%= submit_tag "Valider", class: "btn btn-primary" %>
<% end %>
