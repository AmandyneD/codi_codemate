<% return if message.role == "system" %>

<div class="d-flex mb-3 <%= message.role == "user" ? "justify-content-end" : "justify-content-start" %>">
  <div class="p-3 rounded"
       style="max-width: 70%;
              background: <%= message.role == "user" ? "#0d6efd" : "#f1f3f5" %>;
              color: <%= message.role == "user" ? "white" : "black" %>;">
    <% if message.role == "assistant" %>
      <div style="white-space: pre-wrap;"><%= simple_format(message.content) %></div>
    <% else %>
      <%= simple_format(message.content) %>
    <% end %>
  </div>
</div>
