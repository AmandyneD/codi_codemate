<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Codi Codemate" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Codi Codemate">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="<%= asset_path 'perso_codemate.svg' %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path 'perso_codemate.svg' %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="container-fluid">
      <div class="d-flex justify-content-between align-items-center mb-3 shadow p-3 mb-5 bg-body-tertiary rounded sticky-top">
        <%= link_to root_path, class: "d-flex align-items-center text-decoration-none fw-bold gap-2" do %>
        <%= image_tag "codi.svg", alt: "Codi", height: 40 %>
        <% end %>

        <%= link_to root_path, class: "d-flex align-items-center text-decoration-none fw-bold gap-2" do %>
        <%= image_tag "perso_codemate.svg", alt: "Codemate", height: 60 %>
        <% end %>

        <div class="d-flex gap-4">
          <% if user_signed_in? %>
            <span class="text-muted align-self-center"><%= current_user.email %></span>
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary btn-sm" %>
          <% else %>
            <%= link_to "Se connecter", new_user_session_path, class: "btn btn-outline-secondary btn-sm" %>
            <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-warning btn-sm" %>
          <% end %>
        </div>
      </div>

      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
