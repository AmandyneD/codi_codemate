<p><%= link_to "← Back to project", project_path(@project) %></p>

<h2 class="mb-3">Chat with Codi</h2>

<div class="mb-3">
  <div class="card p-3">
    <strong><%= @project.title %></strong>
    <div class="text-muted">
      <%= @project.category.humanize %> • <%= @project.level.humanize %> • <%= @project.duration.humanize %>
    </div>
  </div>
</div>

<div id="messages"
     class="card p-3 mb-3"
     style="height: 55vh; overflow-y: auto;">
  <% @messages.each do |m| %>
    <% next if m.role == "system" %>
    <%= render "messages/message", message: m %>
  <% end %>

  <div id="chat-bottom"></div>
</div>

<div id="message_form">
  <%= render "messages/form", project: @project %>
</div>

<div class="mt-3">
  <small class="text-muted">
    Astuce : demande “modifie uniquement le tech stack” ou “rends la description plus pro / plus courte”.
    Codi renverra un JSON et le projet sera mis à jour automatiquement.
  </small>
</div>
